---
// src/pages/research.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");

const getStatusColour = (status: string) => {
    switch (status) {
        case "Active":
            return "#10b981";
        case "Completed":
            return "#3b82f6";
        case "Published":
            return "#8b5cf6";
        default:
            return "#94a3b8";
    }
};
---

<BaseLayout title="Research | Daniel Villarruel">
    <div class="header-section fade-in">
        <h1>Research <span class="gradient-text">Projects</span></h1>
        <p class="subtitle">
            An overview of my core projects and publications.
        </p>
    </div>

    <div class="project-grid fade-in-delayed">
        {
            projects.map((project) => (
                <a href={`/research/${project.id}`} class="project-card">
                    <div class="card-image-wrapper">
                        {project.data.image ? (
                            <img
                                src={project.data.image}
                                alt={project.data.title}
                                class="project-image"
                            />
                        ) : (
                            <div class="project-image-placeholder" />
                        )}

                        <div class="card-status">
                            <span
                                class="status-dot"
                                style={`background-color: ${getStatusColour(project.data.status)}; box-shadow: 0 0 8px ${getStatusColour(project.data.status)};`}
                            />
                            {project.data.status}
                        </div>
                    </div>

                    <div class="project-content">
                        <h3>{project.data.title}</h3>
                    </div>
                </a>
            ))
        }
    </div>
</BaseLayout>

<style>
    .header-section {
        margin-bottom: 2rem;
    }

    h1 {
        font-size: clamp(2rem, 4vw, 2.5rem);
        margin-bottom: 0.5rem;
    }

    .subtitle {
        font-size: 1.2rem;
        color: var(--text-secondary);
    }

    .project-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2.5rem;
    }

    .project-card {
        background: var(--bg-secondary);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(150, 150, 150, 0.1);
        transition:
            transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.3s ease,
            border-color 0.3s ease;
        display: flex;
        flex-direction: column;
        color: inherit;
        text-decoration: none;
    }

    .project-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 12px 40px rgba(99, 102, 241, 0.15);
        border-color: rgba(99, 102, 241, 0.3);
    }

    :root[data-theme="light"] .project-card:hover {
        box-shadow: 0 12px 40px rgba(0, 0, 0, 0.08);
    }

    .card-image-wrapper {
        position: relative;
        width: 100%;
        height: 210px;
        overflow: hidden;
    }

    .project-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .project-card:hover .project-image {
        transform: scale(1.05);
    }

    .project-image-placeholder {
        width: 100%;
        height: 100%;
        background: linear-gradient(
            135deg,
            var(--bg-primary),
            var(--bg-secondary)
        );
    }

    .card-status {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: rgba(10, 12, 16, 0.6);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: 0.4rem 0.8rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 500;
        color: #ffffff;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        z-index: 2;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .project-content {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        align-items: center;
    }

    .project-content h3 {
        font-size: 1.1rem;
        margin: 0;
        color: var(--text-primary);
        line-height: 1.5;
    }

    .project-card:hover .project-content h3 {
        color: var(--accent-blue);
    }
</style>
