---
// src/pages/cv.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="CV | Daniel Villarruel">
    <article class="cv-container fade-in">
        <header class="cv-header">
            <div class="header-content">
                <h1>Curriculum Vitae</h1>
                <p class="subtitle">MSc Physics Student & Researcher</p>
            </div>
            <a href="/Daniel_Villarruel_CV.pdf" download class="download-link">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                    ></path><polyline points="7 10 12 15 17 10"></polyline><line
                        x1="12"
                        x2="12"
                        y1="15"
                        y2="3"></line></svg
                >
                Download PDF
            </a>
        </header>

        <section class="cv-section fade-in-delayed">
            <h2>Research Experience</h2>
            <div class="timeline">
                <div class="entry">
                    <div class="entry-header">
                        <span class="role">Research Intern</span>
                        <span class="time">Summer 2026 (Upcoming)</span>
                    </div>
                    <div class="org">
                        Max Planck Institute for Astronomy (MPIA) · Heidelberg,
                        Germany
                    </div>
                    <p class="desc">
                        Working under Dr. Giancarlo Mattia (UFOS) on disc-jet
                        asymmetries.
                    </p>
                </div>

                <div class="entry">
                    <div class="entry-header">
                        <span class="role">Graduate Researcher</span>
                        <span class="time">2023 &ndash; Present</span>
                    </div>
                    <div class="org">CPhys+ Research Group</div>
                    <p class="desc">
                        Conducting HD/MHD simulations of wind-cloud systems in
                        starburst galaxies and exploring ISM/CGM microphysics.
                    </p>
                </div>
            </div>
        </section>

        <section class="cv-section fade-in-delayed">
            <h2>Education</h2>
            <div class="timeline">
                <div class="entry">
                    <div class="entry-header">
                        <span class="role"
                            >MSc in Physics (Fundamental Physics)</span
                        >
                        <span class="time">Expected Feb 2027</span>
                    </div>
                    <div class="org">Yachay Tech University · Ecuador</div>
                </div>

                <div class="entry">
                    <div class="entry-header">
                        <span class="role">BSc in Physics</span>
                        <span class="time">2025</span>
                    </div>
                    <div class="org">Yachay Tech University · Ecuador</div>
                    <p class="desc">Graduated with Honours.</p>
                </div>
            </div>
        </section>

        <section class="cv-section fade-in-delayed-more">
            <h2>Technical Skills</h2>
            <div class="skills-grid">
                <div class="skill-item">
                    <strong>Languages:</strong> Python, C, C++, Julia
                </div>
                <div class="skill-item">
                    <strong>Tools:</strong> PLUTO, Cloudy, yt, Trident
                </div>
            </div>
        </section>

        <section class="cv-section fade-in-delayed-more">
            <h2>Languages</h2>
            <p class="lang-text">
                <strong>Spanish</strong> (Native), <strong>English</strong> (Full
                professional proficiency),
                <strong>German</strong> (B2)
            </p>
        </section>
    </article>
</BaseLayout>

<style>
    .cv-container {
        max-width: 900px;
        margin: 0 auto;
    }

    .cv-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 3.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(150, 150, 150, 0.1);
        margin-top: 1.5rem;
    }

    .cv-header h1 {
        font-size: 1.75rem;
        font-weight: 600;
        margin: 0 0 0.25rem 0;
        letter-spacing: -0.01em;
    }

    .subtitle {
        color: var(--text-secondary);
        font-size: 0.95rem;
        margin: 0;
    }

    .download-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-primary);
        text-decoration: none;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        background: var(--bg-secondary);
        border: 1px solid rgba(150, 150, 150, 0.1);
        transition: all 0.2s ease;
    }

    .download-link:hover {
        border-color: var(--accent-blue);
        color: var(--accent-blue);
        background: rgba(59, 130, 246, 0.05);
    }

    .cv-section {
        margin-bottom: 3.5rem;
    }

    .cv-section h2 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent-blue);
        margin-bottom: 1.5rem;
        opacity: 0.9;
    }

    .timeline {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .entry {
        position: relative;
        padding-bottom: 1.5rem;
        border-bottom: 1px dashed rgba(150, 150, 150, 0.15);
    }

    .entry:last-child {
        padding-bottom: 0;
        border-bottom: none;
    }

    .entry-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.3rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .role {
        font-weight: 600;
        font-family: var(--font-display);
        font-size: 1.1rem;
        color: var(--text-primary);
    }

    .time {
        font-size: 0.8rem;
        color: var(--accent-blue);
        background: rgba(59, 130, 246, 0.08);
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-variant-numeric: tabular-nums;
        border: 1px solid rgba(59, 130, 246, 0.15);
    }

    .org {
        font-size: 0.95rem;
        color: var(--text-secondary);
        margin-bottom: 0.6rem;
    }

    .desc {
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    .skills-grid {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .skill-item {
        font-size: 0.95rem;
        color: var(--text-secondary);
    }

    .skill-item strong {
        color: var(--text-primary);
        font-weight: 500;
        margin-right: 0.5rem;
    }

    .lang-text {
        font-size: 0.95rem;
        color: var(--text-secondary);
    }

    /* Mobile Adjustments */
    @media (max-width: 600px) {
        .cv-header {
            flex-direction: column;
            gap: 1.5rem;
        }

        .entry-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.4rem;
        }
    }
</style>
